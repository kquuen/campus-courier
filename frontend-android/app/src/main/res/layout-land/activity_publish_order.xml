<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/gray_bg">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <EditText android:id="@+id/etTrackingNo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="快递单号 *" android:layout_marginBottom="12dp"
            android:background="@color/white" android:padding="12dp"/>

        <EditText android:id="@+id/etExpressCompany"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="快递公司（如：顺丰、京东）" android:layout_marginBottom="12dp"
            android:background="@color/white" android:padding="12dp"/>

        <EditText android:id="@+id/etPickupAddress"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="取件地址（快递站位置）*" android:layout_marginBottom="12dp"
            android:background="@color/white" android:padding="12dp"/>

        <EditText android:id="@+id/etDeliveryAddress"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="送达地址（宿舍楼/房间号）*" android:layout_marginBottom="12dp"
            android:background="@color/white" android:padding="12dp"/>

        <EditText android:id="@+id/etFee"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="代取费用（元，默认2元）" android:inputType="numberDecimal"
            android:layout_marginBottom="12dp"
            android:background="@color/white" android:padding="12dp"/>

        <EditText android:id="@+id/etRemark"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="备注（选填）" android:minLines="2"
            android:layout_marginBottom="24dp"
            android:background="@color/white" android:padding="12dp"/>

        <Button android:id="@+id/btnSubmit"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="发 布" android:textSize="16sp"
            android:backgroundTint="@color/primary"/>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/gray_bg">

    <!-- 头部卡片 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="140dp"
        android:background="@color/primary" android:orientation="vertical"
        android:gravity="center" android:padding="16dp">
        <TextView android:id="@+id/tvNickname"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/white"/>
        <TextView android:id="@+id/tvPhone"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#BBDEFB" android:layout_marginTop="6dp"/>
        <TextView android:id="@+id/tvRole"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textColor="#BBDEFB" android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- 信息区 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/white"
        android:padding="16dp" android:layout_marginTop="8dp">
        <TextView android:id="@+id/tvCredit"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="15sp" android:gravity="center"/>
        <TextView android:id="@+id/tvBalance"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textSize="15sp" android:gravity="center"
            android:textColor="@color/accent" android:textStyle="bold"/>
    </LinearLayout>

    <!-- 操作按钮 -->
    <Button android:id="@+id/btnApplyCourier"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_margin="16dp" android:text="申请成为代取员"
        android:backgroundTint="@color/accent" android:visibility="gone"/>

    <Button android:id="@+id/btnMyCourierOrders"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginHorizontal="16dp" android:text="查看我接的订单"
        android:backgroundTint="@color/primary" android:visibility="gone"/>
</LinearLayout>

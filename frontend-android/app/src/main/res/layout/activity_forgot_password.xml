<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:padding="20dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">
        <EditText android:id="@+id/etPhone"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="手机号" android:inputType="phone"/>
        <Button android:id="@+id/btnSendCode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="获取验证码（模拟短信）" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/etCode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="6位验证码" android:inputType="number" android:layout_marginTop="16dp"/>
        <EditText android:id="@+id/etNewPwd"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="新密码（6-20位）" android:inputType="textPassword" android:layout_marginTop="8dp"/>
        <Button android:id="@+id/btnReset"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="重置密码" android:layout_marginTop="24dp"
            android:backgroundTint="@color/accent"/>
    </LinearLayout>
</ScrollView>

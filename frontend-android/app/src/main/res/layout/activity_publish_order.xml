<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSubmit"
        android:layout_marginBottom="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 表单标题 -->
            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发布代取订单"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="24dp" />

            <!-- 快递单号 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilTrackingNo"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="快递单号 *"
                app:layout_constraintTop_toBottomOf="@id/tvFormTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_barcode"
                app:errorEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTrackingNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 快递公司 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilExpressCompany"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="快递公司"
                app:layout_constraintTop_toBottomOf="@id/tilTrackingNo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_express"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExpressCompany"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 取件地址 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPickupAddress"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="取件地址 *"
                app:layout_constraintTop_toBottomOf="@id/tilExpressCompany"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_pickup"
                app:errorEnabled="true"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPickupAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="2"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 送达地址 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilDeliveryAddress"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="送达地址 *"
                app:layout_constraintTop_toBottomOf="@id/tilPickupAddress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_delivery"
                app:errorEnabled="true"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDeliveryAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="2"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 代取费用 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilFee"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="代取费用（元）"
                app:layout_constraintTop_toBottomOf="@id/tilDeliveryAddress"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_fee"
                app:errorEnabled="true"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:text="2.00"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 期望送达时间 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilExpectedTime"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="期望送达时间（选填）"
                app:layout_constraintTop_toBottomOf="@id/tilFee"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_time"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExpectedTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 备注 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRemark"
                style="@style/Widget.CampusCourier.TextInputLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="备注（选填）"
                app:layout_constraintTop_toBottomOf="@id/tilExpectedTime"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:startIconDrawable="@drawable/ic_remark"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRemark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:imeOptions="actionDone" />

            </com.google.android.material.textfield.TextInputLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 发布按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmit"
        style="@style/Widget.CampusCourier.Button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="发布订单"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 加载指示器 -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/gray_300"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_bg"
    android:padding="16dp">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        android:layout_marginBottom="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 订单状态时间线 -->
            <com.campus.courier.view.OrderStatusTimelineView
                android:id="@+id/statusTimelineView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="24dp" />

            <!-- 订单信息卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface"
                app:layout_constraintTop_toBottomOf="@id/statusTimelineView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- 状态标题 -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="状态：待接单"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginBottom="16dp" />

                    <!-- 订单号 -->
                    <TextView
                        android:id="@+id/tvOrderNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="订单号："
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintTop_toBottomOf="@id/tvStatus"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginBottom="12dp" />

                    <!-- 快递单号 -->
                    <TextView
                        android:id="@+id/tvTracking"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="快递单号："
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toBottomOf="@id/tvOrderNo"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginBottom="12dp" />

                    <!-- 取件地址 -->
                    <TextView
                        android:id="@+id/tvPickup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="取件地址："
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toBottomOf="@id/tvTracking"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginBottom="12dp" />

                    <!-- 送达地址 -->
                    <TextView
                        android:id="@+id/tvDelivery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="送达地址："
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        app:layout_constraintTop_toBottomOf="@id/tvPickup"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginBottom="12dp" />

                    <!-- 代取费 -->
                    <TextView
                        android:id="@+id/tvFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        app:layout_constraintTop_toBottomOf="@id/tvDelivery"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="代取费用"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintBottom_toBottomOf="@id/tvFee"
                        app:layout_constraintStart_toEndOf="@id/tvFee"
                        android:layout_marginStart="8dp" />

                    <!-- 备注 -->
                    <TextView
                        android:id="@+id/tvRemark"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="备注："
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintTop_toBottomOf="@id/tvFee"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginBottom="12dp" />

                    <!-- 期望时间 -->
                    <TextView
                        android:id="@+id/tvExpectedTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="期望时间："
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        app:layout_constraintTop_toBottomOf="@id/tvRemark"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:visibility="gone" />

                    <!-- 申诉原因 -->
                    <TextView
                        android:id="@+id/tvAppeal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="申诉原因："
                        android:textSize="13sp"
                        android:textColor="@color/error"
                        app:layout_constraintTop_toBottomOf="@id/tvExpectedTime"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 支付提示 -->
            <TextView
                android:id="@+id/tvPayHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="请先完成支付，支付后代取员才能在广场看到本单。"
                android:textSize="13sp"
                android:textColor="@color/warning"
                android:padding="12dp"
                android:background="@drawable/bg_rounded_outline"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cardOrderInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 按钮容器 -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAction"
            style="@style/Widget.CampusCourier.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="接单"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPay"
            style="@style/Widget.CampusCourier.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="立即支付"
            android:backgroundTint="@color/accent"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReview"
            style="@style/Widget.CampusCourier.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:text="去评价"
            android:backgroundTint="@color/success"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                style="@style/Widget.CampusCourier.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:layout_weight="1"
                android:text="取消订单"
                android:visibility="gone"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAppeal"
                style="@style/Widget.CampusCourier.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:layout_weight="1"
                android:text="异常申诉"
                android:backgroundTint="@color/warning"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 加载指示器 -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:indicatorColor="@color/primary"
        app:trackColor="@color/gray_300"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
